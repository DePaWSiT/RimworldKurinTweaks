<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Remove flower requirement on T3-->
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinRemoveConvolleraRequirementToggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationRemove">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_CombatT3"]/prerequisites/li[text()="Kurin_Flower"]</xpath>
      </Operation>
      <Operation Class="PatchOperationRemove">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_ApparelT3"]/prerequisites/li[text()="Kurin_Flower"]</xpath>
      </Operation>
      <Operation Class="PatchOperationRemove" MayRequire="Ludeon.Rimworld.Biotech">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_Mechtech"]/prerequisites/li[text()="Kurin_Flower"]</xpath>
      </Operation>
    </caseTrue>
  </Operation>
  <!-- Set tech level correctly -->
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinSetAppropriateTechLevelToggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_ApparelT1"]/techLevel</xpath>
        <value>
          <techLevel>Medieval</techLevel>
        </value>
      </Operation>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_ApparelT2"]/techLevel</xpath>
        <value>
          <techLevel>Medieval</techLevel>
        </value>
      </Operation>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_ApparelT3"]/techLevel</xpath>
        <value>
          <techLevel>Medieval</techLevel>
        </value>
      </Operation>
    </caseTrue>
  </Operation>
  <!-- Remove smithing from the research requirements -->
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinRemoveSmithingFromT2Toggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationRemove">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_CombatT2"]/prerequisites/li[text()="Smithing"]</xpath>
      </Operation>
    </caseTrue>
  </Operation>
  <!-- Set republic armor to require the Marine armor research  instead of fabrication -->
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinResearchMarineArmorForApparelT4</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationRemove">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_ApparelT4"]/prerequisites/li[text()="Fabrication"]</xpath>
      </Operation>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_ApparelT4"]/prerequisites</xpath>
        <value>
          <li>PoweredArmor</li>
        </value>
      </Operation>
    </caseTrue>
  </Operation>
  <!-- Flower research cost-->
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinResearchCostFlower</key>
    <defaultValue>1200</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ResearchProjectDef[defName = "Kurin_Flower"]/baseCost</xpath>
        <value>
          <baseCost>{DePaWSiTKurinResearchCostFlower}</baseCost>
        </value>
      </Operation>
    </apply>
  </Operation>
  <!-- Basic clothing research cost -->
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinResearchCostApparelT1</key>
    <defaultValue>400</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
