          <baseCost>{DePaWSiTKurinResearchCostApparelT1}</baseCost>
        </value>
      </Operation>
    </apply>
  </Operation>
  <!-- Advanced clothing research cost -->
  <Operation Class="XmlExtensions.UseSetting">
