  </Operation>
  <!-- Mechtech research cost -->
  <Operation Class="XmlExtensions.UseSetting" MayRequire="Ludeon.Rimworld.Biotech">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinResearchCostMechtech</key>
