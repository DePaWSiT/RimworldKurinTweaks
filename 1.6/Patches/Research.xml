<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinRemoveConvolleraRequirementToggle</li>
      <li>DePaWSiTKurinSetAppropriateTechLevelToggle</li>
      <li>DePaWSiTKurinRemoveSmithingFromT2Toggle</li>
      <li>DePaWSiTKurinResearchMarineArmorForApparelT4</li>
      <li>DePaWSiTKurinBodyArmorToAdvancedCombatToggle</li>
      <li>DePaWSiTKurinResearchCostFlower</li>
      <li>DePaWSiTKurinResearchCostApparelT1</li>
      <li>DePaWSiTKurinResearchCostApparelT2</li>
      <li>DePaWSiTKurinResearchCostApparelT3</li>
      <li>DePaWSiTKurinResearchCostApparelT4</li>
      <li>DePaWSiTKurinResearchCostCombatT2</li>
      <li>DePaWSiTKurinResearchCostCombatT3</li>
      <li>DePaWSiTKurinResearchCostCombatT4</li>
      <li>DePaWSiTKurinResearchCostMechtech</li>
      <li>DePaWSiTKurinResearchCostTurret</li>
    </keys>
    <defaultValues>
      <!-- Convollera requirement -->
      <li>false</li>
      <!-- Apparel tech level -->
      <li>false</li>
      <!-- remove smithing from T2 -->
      <li>false</li>
      <!-- Marine armor toggle T4 -->
      <li>false</li>
      <!-- Body armor to Advanced Combat -->
      <li>false</li>
      <!-- flower research cost -->
      <li>1200</li>
      <!-- cost apparelT1 -->
      <li>400</li>
      <!-- cost apparelT2 -->
      <li>800</li>
      <!-- cost apparelT3 -->
      <li>1200</li>
      <!-- cost apparelT4 -->
      <li>1600</li>
      <!-- cost combatT2 -->
      <li>800</li>
      <!-- cost combatT3 -->
      <li>1200</li>
      <!-- cost combatT4 -->
      <li>1600</li>
      <!-- cost mechtech -->
      <li>400</li>
      <!-- cost turret -->
      <li>400</li>
    </defaultValues>
    <apply>
      <!-- ApparelT1 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_ApparelT1"]</xpath>
        <value>
          <techLevel Condition="{DePaWSiTKurinSetAppropriateTechLevelToggle}" Operation="Replace">Medieval</techLevel>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostApparelT1}</baseCost>
        </value>
      </Operation>
      <!-- ApparelT2 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_ApparelT2"]</xpath>
        <value>
          <techLevel Condition="{DePaWSiTKurinSetAppropriateTechLevelToggle}" Operation="Replace">Medieval</techLevel>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostApparelT2}</baseCost>
        </value>
      </Operation>
      <!-- ApparelT3 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_ApparelT3"]</xpath>
        <value>
          <techLevel Condition="{DePaWSiTKurinSetAppropriateTechLevelToggle}" Operation="Replace">Medieval</techLevel>
          <prerequisites Condition="{DePaWSiTKurinRemoveConvolleraRequirementToggle}" Operation="Safe">
            <li Compare="InnerText" Operation="Remove">Kurin_Flower</li>
          </prerequisites>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostApparelT3}</baseCost>
        </value>
      </Operation>
      <!-- ApparelT4 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_ApparelT4"]</xpath>
        <value>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostApparelT4}</baseCost>
          <prerequisites Condition="{DePaWSiTKurinResearchMarineArmorForApparelT4}" Operation="Safe">
            <li Compare="InnerText" Operation="Remove">Fabrication</li>
            <li Operation="Add">PoweredArmor</li>
          </prerequisites>
        </value>
      </Operation>
      <!-- CombatT2 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_CombatT2"]</xpath>
        <value>
          <prerequisites Condition="{DePaWSiTKurinRemoveSmithingFromT2Toggle}" Operation="Safe">
            <li Compare="InnerText" Operation="Remove">Smithing</li>
          </prerequisites>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostCombatT2}</baseCost>
          <techLevel Condition="{DePaWSiTKurinBodyArmorToAdvancedCombatToggle}" Operation="Replace">Medieval</techLevel>
        </value>
      </Operation>
      <!-- CombatT3 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_CombatT3"]</xpath>
        <value>
          <prerequisites Condition="{DePaWSiTKurinRemoveConvolleraRequirementToggle}" Operation="Safe">
            <li Compare="InnerText" Operation="Remove">Kurin_Flower</li>
          </prerequisites>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostCombatT3}</baseCost>
        </value>
      </Operation>
      <!-- CombatT4 -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_CombatT4"]</xpath>
        <value>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostCombatT4}</baseCost>
        </value>
      </Operation>
      <!-- Mechtech -->
      <Operation Class="XmlExtensions.HybridPatch" MayRequire="Ludeon.Rimworld.Biotech">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_Mechtech"]</xpath>
        <value>
          <prerequisites Condition="{DePaWSiTKurinRemoveConvolleraRequirementToggle}" Operation="Safe">
            <li Compare="InnerText" Operation="Remove">Kurin_Flower</li>
          </prerequisites>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostMechtech}</baseCost>
        </value>
      </Operation>
      <!-- Flower -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_Flower"]</xpath>
        <value>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostFlower}</baseCost>
        </value>
      </Operation>
      <!-- Turret -->
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ResearchProjectDef[defName= "Kurin_Turret"]</xpath>
        <value>
          <baseCost Operation="Replace">{DePaWSiTKurinResearchCostTurret}</baseCost>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
