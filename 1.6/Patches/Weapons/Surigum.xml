<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
      <li>DePaWSiTKurinRemoveSmithingFromT2Toggle</li>
      <li>DePaWSiTKurinMakeSurigumAtSmithingTableToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Surigum"]</xpath>
        <value>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">2400</WorkToMake>
            <AccuracyTouch Operation="Replace">0.70</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.73</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.33</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.22</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">0.7</RangedWeapon_Cooldown>
          </statBases>
          <costList Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <Steel Operation="Replace">40</Steel>
          </costList>
          <recipeMaker Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <skillRequirements Operation="Safe">
              <Crafting Operation="Replace">3</Crafting>
            </skillRequirements>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinRemoveSmithingFromT2Toggle}" Operation="Safe">
            <researchPrerequisite Operation="Add">Kurin_CombatT2</researchPrerequisite>
            <researchPrerequisites Operation="Safe">
              <li Compare="InnerText" Operation="Remove">Kurin_CombatT2</li>
              <li Operation="Add">Smithing</li>
            </researchPrerequisites>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinMakeSurigumAtSmithingTableToggle}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">FueledSmithy</li>
              <li Operation="Add">ElectricSmithy</li>
            </recipeUsers>
          </recipeMaker>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">0.7</warmupTime>
              <range Operation="Replace">16</range>
            </li>
          </verbs>
          <tools Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="power">
              <power Operation="Replace">11</power>
              <cooldownTime Operation="Replace">0.8</cooldownTime>
            </li>
          </tools>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Surigum"]</xpath>
        <value>
          <projectile Operation="Safe">
            <speed Operation="Replace">80</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
