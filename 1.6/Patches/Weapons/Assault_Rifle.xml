<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinFixGunsmithingRequirementToggle</li>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Assault_Rifle"]</xpath>
        <value>
          <recipeMaker Condition="{DePaWSiTKurinFixGunsmithingRequirementToggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Compare="Both" Operation="Remove">Kurin_CombatT3</li>
            </researchPrerequisites>
            <researchPrerequisite Operation="Add">Kurin_CombatT3</researchPrerequisite>
          </recipeMaker>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">31500</WorkToMake>
            <AccuracyTouch Operation="Replace">0.79</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.89</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.80</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.68</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">0.75</RangedWeapon_Cooldown>
          </statBases>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">1.00</warmupTime>
              <ticksBetweenBurstShots Operation="Replace">8</ticksBetweenBurstShots>
              <burstShotCount Operation="Replace">2</burstShotCount>
            </li>
          </verbs>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Assault_Rifle"]</xpath>
        <value>
          <projectile Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <damageAmountBase Operation="Replace">15</damageAmountBase>
            <stoppingPower Operation="Replace">1.4</stoppingPower>
            <armorPenetrationBase Operation="Replace">0.21</armorPenetrationBase>
            <speed Operation="Replace">290</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
