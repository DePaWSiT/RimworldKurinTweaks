<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
      <li>DePaWSiTKurinFixGunsmithingRequirementToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Charge_Shotgun"]</xpath>
        <value>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">42000</WorkToMake>
            <AccuracyTouch Operation="Replace">0.77</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.84</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.62</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.42</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">1.6</RangedWeapon_Cooldown>
          </statBases>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">0.9</warmupTime>
              <ticksBetweenBurstShots Operation="Replace">30</ticksBetweenBurstShots>
              <burstShotCount Operation="Replace">4</burstShotCount>
              <pelletCount Operation="Replace">3</pelletCount>
            </li>
          </verbs>
          <recipeMaker Condition="{DePaWSiTKurinFixGunsmithingRequirementToggle}" Operation="Safe">
            <researchPrerequisites Operation="Remove"></researchPrerequisites>
            <researchPrerequisite Operation="Add">Kurin_CombatT4</researchPrerequisite>
          </recipeMaker>
          <costList Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <Plasteel Operation="Replace">65</Plasteel>
            <ComponentSpacer Operation="Replace">2</ComponentSpacer>
          </costList>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Charge_Shotgun"]</xpath>
        <value>
          <projectile Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <armorPenetrationBase Operation="Replace">0.22</armorPenetrationBase>
            <speed Operation="Replace">170</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
