<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinFixGunsmithingRequirementToggle</li>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Sniper_Rifle"]</xpath>
        <value>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">43200</WorkToMake>
            <Mass Operation="Replace">3.8</Mass>
            <AccuracyTouch Operation="Replace">0.60</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.70</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.90</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.93</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">1.85</RangedWeapon_Cooldown>
          </statBases>
          <costList Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <Steel Operation="Replace">65</Steel>
            <ComponentIndustrial Operation="Replace">8</ComponentIndustrial>
          </costList>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">2.60</warmupTime>
              <range Operation="Replace">41</range>
            </li>
          </verbs>
          <recipeMaker Condition="{DePaWSiTKurinFixGunsmithingRequirementToggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Compare="InnerText" Operation="Remove">Kurin_CombatT3</li>
            </researchPrerequisites>
            <researchPrerequisite Operation="Add">Kurin_CombatT3</researchPrerequisite>
          </recipeMaker>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Sniper_Rifle"]</xpath>
        <value>
          <projectile Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <damageAmountBase Operation="Replace">29</damageAmountBase>
            <stoppingPower Operation="Replace">2.4</stoppingPower>
            <armorPenetrationBase Operation="Replace">0.31</armorPenetrationBase>
            <speed Operation="Replace">320</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
