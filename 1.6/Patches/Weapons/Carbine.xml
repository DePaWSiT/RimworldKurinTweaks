<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinFixGunsmithingRequirementToggle</li>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Carbine"]</xpath>
        <value>
          <recipeMaker Condition="{DePaWSiTKurinFixGunsmithingRequirementToggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Compare="Both" Operation="Remove">Kurin_CombatT3</li>
            </researchPrerequisites>
            <researchPrerequisite Operation="Add">Kurin_CombatT3</researchPrerequisite>
          </recipeMaker>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">28800</WorkToMake>
            <AccuracyTouch Operation="Replace">0.77</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.83</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.79</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.66</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">1.30</RangedWeapon_Cooldown>
          </statBases>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">1.00</warmupTime>
              <ticksBetweenBurstShots Operation="Replace">12</ticksBetweenBurstShots>
              <burstShotCount Operation="Replace">3</burstShotCount>
              <range Operation="Replace">25</range>
              <defaultProjectile Operation="Replace">Kurin_Bullet_Carbine</defaultProjectile>
            </li>
          </verbs>
          <costList Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <ComponentIndustrial Operation="Replace">4</ComponentIndustrial>
          </costList>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Carbine"]</xpath>
        <value>
          <projectile Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <damageAmountBase Operation="Replace">14</damageAmountBase>
            <stoppingPower Operation="Replace">1.2</stoppingPower>
            <armorPenetrationBase Operation="Replace">0.23</armorPenetrationBase>
            <speed Operation="Replace">300</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
