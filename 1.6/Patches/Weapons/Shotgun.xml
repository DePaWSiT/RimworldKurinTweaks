<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinFixGunsmithingRequirementToggle</li>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Shotgun"]</xpath>
        <value>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">12000</WorkToMake>
            <AccuracyTouch Operation="Replace">0.80</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.86</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.69</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.4</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">1.4</RangedWeapon_Cooldown>
          </statBases>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">1.2</warmupTime>
              <range Operation="Replace">16</range>
              <pelletCount Operation="Remove"></pelletCount>
              <ticksBetweenBurstShots Operation="Add">0</ticksBetweenBurstShots>
              <burstShotCount Operation="Add">7</burstShotCount>
            </li>
          </verbs>
          <costList Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <Steel Operation="Replace">60</Steel>
            <ComponentIndustrial Operation="Replace">3</ComponentIndustrial>
          </costList>
          <recipeMaker Condition="{DePaWSiTKurinFixGunsmithingRequirementToggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Compare="InnerText" Operation="Remove">Kurin_CombatT3</li>
            </researchPrerequisites>
            <researchPrerequisite Operation="Add">Kurin_CombatT3</researchPrerequisite>
          </recipeMaker>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Shotgun"]</xpath>
        <value>
          <projectile Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <damageAmountBase Operation="Replace">8</damageAmountBase>
            <stoppingPower Operation="Replace">1.8</stoppingPower>
            <armorPenetrationBase Operation="Replace">0.08</armorPenetrationBase>
            <speed Operation="Replace">150</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
