<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinPolearmCraftingRequirement</li>
      <li>DePaWSiTKurinPolearmResearchRequirementsToggle</li>
    </keys>
    <defaultValues>
      <li>14</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_MeleeWeapon_Ceremonial_Polearm"]</xpath>
        <value>
          <recipeMaker Operation="Safe">
            <skillRequirements Operation="Safe">
              <Crafting Operation="Replace">{DePaWSiTKurinPolearmCraftingRequirement}</Crafting>
            </skillRequirements>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinPolearmResearchRequirementsToggle}" Operation="Safe">
            <researchPrerequisite Operation="Replace">Kurin_CombatT3</researchPrerequisite>
            <researchPrerequisites Operation="Safe">
              <li Compare="Both" Operation="Remove">Kurin_CombatT3</li>
              <li Operation="Add">LongBlades</li>
            </researchPrerequisites>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
