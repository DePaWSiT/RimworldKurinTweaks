<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinCeremonialSwordCraftingRequirement</li>
    </keys>
    <defaultValues>
      <li>10</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_MeleeWeapon_Ceremonial_Sword"]</xpath>
        <value>
          <recipeMaker Operation="Safe">
            <skillRequirements Operation="Safe">
              <Crafting Operation="Replace">{DePaWSiTKurinCeremonialSwordCraftingRequirement}</Crafting>
            </skillRequirements>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
