<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinCeremonialSwordCraftingRequirement</key>
    <defaultValue>10</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_MeleeWeapon_Ceremonial_Sword"]/recipeMaker/skillRequirements/Crafting</xpath>
        <value>
          <Crafting>{DePaWSiTKurinCeremonialSwordCraftingRequirement}</Crafting>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
