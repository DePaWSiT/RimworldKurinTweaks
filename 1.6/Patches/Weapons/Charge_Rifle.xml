<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinWeaponConfigToggle</li>
      <li>DePaWSiTKurinFixGunsmithingRequirementToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Gun_Charge_Rifle"]</xpath>
        <value>
          <statBases Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <WorkToMake Operation="Replace">46800</WorkToMake>
            <Mass Operation="Replace">4.5</Mass>
            <AccuracyTouch Operation="Replace">0.78</AccuracyTouch>
            <AccuracyShort Operation="Replace">0.89</AccuracyShort>
            <AccuracyMedium Operation="Replace">0.87</AccuracyMedium>
            <AccuracyLong Operation="Replace">0.70</AccuracyLong>
            <RangedWeapon_Cooldown Operation="Replace">1.25</RangedWeapon_Cooldown>
          </statBases>
          <verbs Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <li Operation="Safe" XPathLocal="warmupTime">
              <warmupTime Operation="Replace">0.9</warmupTime>
              <burstShotCount Operation="Replace">3</burstShotCount>
            </li>
          </verbs>
          <costList Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <Plasteel Operation="Replace">60</Plasteel>
            <ComponentSpacer Operaton="Replace">2</ComponentSpacer>
          </costList>
          <recipeMaker Condition="{DePaWSiTKurinFixGunsmithingRequirementToggle}" Operation="Safe">
            <researchPrerequisites Operation="Remove"></researchPrerequisites>
            <researchPrerequisite Operation="Add">Kurin_CombatT4</researchPrerequisite>
          </recipeMaker>
        </value>
      </Operation>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Bullet_Charge_Rifle"]</xpath>
        <value>
          <projectile Condition="{DePaWSiTKurinWeaponConfigToggle}" Operation="Safe">
            <damageAmountBase Operation="Replace">16</damageAmountBase>
            <stoppingPower Operation="Replace">1.6</stoppingPower>
            <armorPenetrationBase Operation="Replace">0.29</armorPenetrationBase>
            <speed Operation="Replace">300</speed>
          </projectile>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
