<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</li>
      <li>DePaWSiTKurinArmorGothWeight</li>
      <li>DePaWSiTKurinArmorGothSensOffset</li>
      <li>DePaWSiTKurinArmorGothStuffEffectMultiplier</li>
      <li>DePaWSiTKurinArmorGothMoveSpeedOffset</li>
      <li>DePaWSiTKurinAddMiddleLayerArmorGoth</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>0.40</li>
      <li>0.25</li>
      <li>0.55</li>
      <li>-0.20</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Armored_Gothic_Dress"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinArmorGothWeight}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinArmorGothStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <PsychicSensitivityOffset Operation="Replace">{DePaWSiTKurinArmorGothSensOffset}</PsychicSensitivityOffset>
            <MoveSpeed Operation="Replace">{DePaWSiTKurinArmorGothMoveSpeedOffset}</MoveSpeed>
          </equippedStatOffsets>
          <recipeMaker Condition="{DePaWSiTKurinResearchAddFlakToCombatT3Toggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Operation="Add">FlakArmor</li>
            </researchPrerequisites>
          </recipeMaker>
          <apparel Condition="{DePaWSiTKurinAddMiddleLayerArmorGoth}" Operation="Safe">
            <layers Operation="Safe">
              <li Operation="Add">Middle</li>
            </layers>
          </apparel>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
