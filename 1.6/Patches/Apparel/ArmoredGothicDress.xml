<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- add flak as requirement, Def doesn't have recipeMaker so you get this abomination... -->
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <!-- NOTE: hybrid patch operation -->
      <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Armored_Gothic_Dress"]/recipeMaker</xpath>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Armored_Gothic_Dress"]</xpath>
          <value>
            <recipeMaker>
              <researchPrerequisites>
                <li>FlakArmor</li>
              </researchPrerequisites>
            </recipeMaker>
          </value>
        </nomatch>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Armored_Gothic_Dress"]/recipeMaker/researchPrerequisites</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Armored_Gothic_Dress"]/recipeMaker</xpath>
            <value>
              <researchPrerequisites>
                <li>FlakArmor</li>
              </researchPrerequisites>
            </value>
          </nomatch>
          <match Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Armored_Gothic_Dress"]/recipeMaker/researchPrerequisites</xpath>
            <value>
              <li>FlakArmor</li>
            </value>
          </match>
        </match>
      </Operation>
    </caseTrue>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinArmorGothWeight</key>
    <defaultValue>0.40</defaultValue>
    <apply>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Armored_Gothic_Dress"]/statBases</xpath>
        <value>
          <Mass>{DePaWSiTKurinArmorGothWeight}</Mass>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinArmorGothSensOffset</key>
    <defaultValue>0.25</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Armored_Gothic_Dress"]/equippedStatOffsets/PsychicSensitivityOffset</xpath>
        <value>
          <PsychicSensitivityOffset>{DePaWSiTKurinArmorGothSensOffset}</PsychicSensitivityOffset>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinArmorGothStuffEffectMultiplier</key>
    <defaultValue>0.55</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Armored_Gothic_Dress"]/statBases/StuffEffectMultiplierArmor</xpath>
        <value>
          <StuffEffectMultiplierArmor>{DePaWSiTKurinArmorGothStuffEffectMultiplier}</StuffEffectMultiplierArmor>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinArmorGothMoveSpeedOffset</key>
    <defaultValue>-0.20</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Armored_Gothic_Dress"]/equippedStatOffsets/MoveSpeed</xpath>
        <value>
          <MoveSpeed>{DePaWSiTKurinArmorGothMoveSpeedOffset}</MoveSpeed>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinAddMiddleLayerArmorGoth</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Armored_Gothic_Dress"]/apparel</xpath>
        <value>
          <layers>
            <li>Middle</li>
          </layers>
        </value>
      </Operation>
    </caseTrue>
  </Operation>
</Patch>
