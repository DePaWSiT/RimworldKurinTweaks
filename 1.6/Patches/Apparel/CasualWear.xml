<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinCasualWearDodgeChance</li>
    </keys>
    <defaultValues>
      <li>0.0</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Casual_Wear"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <MeleeDodgeChance Operation="Add">{DePaWSiTKurinCasualWearDodgeChance}</MeleeDodgeChance>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
