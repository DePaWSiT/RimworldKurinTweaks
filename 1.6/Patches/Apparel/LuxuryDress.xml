<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinLuxuryDressSocialImpact</key>
    <defaultValue>0.4</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Luxury_Dress"]/equippedStatOffsets/SocialImpact</xpath>
        <value>
          <SocialImpact>{DePaWSiTKurinLuxuryDressSocialImpact}</SocialImpact>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinLuxuryDressTradeImprovement</key>
    <defaultValue>0.25</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Luxury_Dress"]/equippedStatOffsets/TradePriceImprovement</xpath>
        <value>
          <TradePriceImprovement>{DePaWSiTKurinLuxuryDressTradeImprovement}</TradePriceImprovement>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
