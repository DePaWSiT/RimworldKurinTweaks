<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinNunDressTendSpeed</li>
      <li>DePaWSiTKurinNunDressTendQuality</li>
    </keys>
    <defaultValues>
      <li>0.2</li>
      <li>0.1</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Nun_Dress"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <MedicalTendSpeed Operation="Replace">{DePaWSiTKurinNunDressTendSpeed}</MedicalTendSpeed>
            <MedicalTendQuality Operation="Replace">{DePaWSiTKurinNunDressTendQuality}</MedicalTendQuality>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
