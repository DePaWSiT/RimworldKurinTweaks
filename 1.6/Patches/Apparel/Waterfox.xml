<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinPowerArmorFabricationToggle</li>
      <li>DePaWSiTKurinRemoveT0RequirementFromWaterfoxToggle</li>
      <li>DePaWSiTKurinWaterfoxArmorMass</li>
      <li>DePaWSiTKurinWaterfoxArmorWorkSpeed</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
      <li>0.20</li>
      <li>0.3</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Waterfox_Armor"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinWaterfoxArmorMass}</Mass>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <WorkSpeedGlobal Operation="Replace">{DePaWSiTKurinWaterfoxArmorWorkSpeed}</WorkSpeedGlobal>
          </equippedStatOffsets>
          <recipeMaker Condition="{DePaWSiTKurinPowerArmorFabricationToggle}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">FabricationBench</li>
            </recipeUsers>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinRemoveT0RequirementFromWaterfoxToggle}" Operation="Safe">
            <researchPrerequisite Operation="Add">Kurin_ApparelT4</researchPrerequisite>
            <researchPrerequisites Compare="Both" Operation="SafeRemove">Kurin_ApparelT4</researchPrerequisites>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
