<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</li>
      <li>DePaWSiTKurinMetalApparelAtMachiningTable</li>
      <li>DePaWSiTKurinBikiniArmorMiddleLayerToggle</li>
      <li>DePaWSiTKurinBikiniArmorMass</li>
      <li>DePaWSiTKurinBikiniArmorStuffEffectMultiplier</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
      <li>false</li>
      <li>0.40</li>
      <li>0.35</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Bikini_Armor"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinBikiniArmorMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinBikiniArmorStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <recipeMaker Condition="{DePaWSiTKurinResearchAddFlakToCombatT3Toggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Operation="Add">FlakArmor</li>
            </researchPrerequisites>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinMetalApparelAtMachiningTable}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">TableMachining</li>
            </recipeUsers>
          </recipeMaker>
          <apparel Condition="{DePaWSiTKurinBikiniArmorMiddleLayerToggle}" Operation="Safe">
            <layers Operation="Safe">
              <li Operation="Add">Middle</li>
            </layers>
          </apparel>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
