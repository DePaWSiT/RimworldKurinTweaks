<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</li>
      <li>DePaWSiTKurinBikiniArmorHeadgearMass</li>
      <li>DePaWSiTKurinBikiniArmorHeadgearStuffEffectMultiplier</li>
      <li>DePaWSiTKurinBikiniArmorHeadgearMeleeHit</li>
      <li>DePaWSiTKurinBikiniArmorHeadgearMeleeDodge</li>
      <li>DePaWSiTKurinBikiniArmorHeadgearMovespeed</li>
      <li>DePaWSiTKurinMetalApparelAtMachiningTable</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>0.20</li>
      <li>0.30</li>
      <li>1.0</li>
      <li>2.0</li>
      <li>0.1</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_Bikini_Armor_Headgear"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinBikiniArmorHeadgearMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinBikiniArmorHeadgearStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <MeleeHitChance Operation="Replace">{DePaWSiTKurinBikiniArmorHeadgearMeleeHit}</MeleeHitChance>
            <MeleeDodgeChance Operation="Replace">{DePaWSiTKurinBikiniArmorHeadgearMeleeDodge}</MeleeDodgeChance>
            <MoveSpeed Operation="Replace">{DePaWSiTKurinBikiniArmorHeadgearMovespeed}</MoveSpeed>
          </equippedStatOffsets>
          <recipeMaker Operation="Safe">
            <researchPrerequisites Condition="{DePaWSiTKurinResearchAddFlakToCombatT3Toggle}" Operation="Safe">
              <li Operation="Add">FlakArmor</li>
            </researchPrerequisites>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinMetalApparelAtMachiningTable}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">TableMachining</li>
            </recipeUsers>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
