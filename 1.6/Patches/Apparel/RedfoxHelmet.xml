<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinPowerArmorFabricationToggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]</xpath>
        <value>
          <recipeMaker>
            <recipeUsers Inherit="False">
              <li>FabricationBench</li>
            </recipeUsers>
          </recipeMaker>
        </value>
      </Operation>
    </caseTrue>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxHelmetMass</key>
    <defaultValue>1.5</defaultValue>
    <apply>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]/statBases</xpath>
        <value>
          <Mass>{DePaWSiTKurinRedfoxHelmetMass}</Mass>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxHelmetMeleeHit</key>
    <defaultValue>2.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]/equippedStatOffsets/MeleeHitChance</xpath>
        <value>
          <MeleeHitChance>{DePaWSiTKurinRedfoxHelmetMeleeHit}</MeleeHitChance>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxHelmetAimDelay</key>
    <defaultValue>-0.2</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]/equippedStatOffsets/AimingDelayFactor</xpath>
        <value>
          <AimingDelayFactor>{DePaWSiTKurinRedfoxHelmetAimDelay}</AimingDelayFactor>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxHelmetDodgeChance</key>
    <defaultValue>3.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]/equippedStatOffsets/MeleeDodgeChance</xpath>
        <value>
          <MeleeDodgeChance>{DePaWSiTKurinRedfoxHelmetDodgeChance}</MeleeDodgeChance>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxHelmetMoveSpeed</key>
    <defaultValue>0.1</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]/equippedStatOffsets/MoveSpeed</xpath>
        <value>
          <MoveSpeed>{DePaWSiTKurinRedfoxHelmetMoveSpeed}</MoveSpeed>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting" MayRequire="Ludeon.Rimworld.Odyssey">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxHelmetVacuumResistance</key>
    <defaultValue>0.65</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Helmet"]/equippedStatOffsets/VacuumResistance</xpath>
        <value>
          <VacuumResistance MayRequire="Ludeon.Rimworld.Odyssey">{DePaWSiTKurinRedfoxHelmetVacuumResistance}</VacuumResistance>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
