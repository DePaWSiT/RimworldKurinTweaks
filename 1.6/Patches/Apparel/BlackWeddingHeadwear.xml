<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinBWHMass</li>
      <li>DePaWSiTKurinBWHStuffEffectMultiplier</li>
      <li>DePaWSiTKurinBWHMeleeHit</li>
      <li>DePaWSiTKurinBWHMeleeDodge</li>
      <li>DePaWSiTKurinBWHMovespeed</li>
    </keys>
    <defaultValues>
      <li>0.20</li>
      <li>0.30</li>
      <li>1.0</li>
      <li>2.0</li>
      <li>0.1</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_Black_Wedding_Headwear"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinBWHMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinBWHStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <MeleeHitChance Operation="Replace">{DePaWSiTKurinBWHMeleeHit}</MeleeHitChance>
            <MeleeDodgeChance Operation="Replace">{DePaWSiTKurinBWHMeleeDodge}</MeleeDodgeChance>
            <MoveSpeed Operation="Replace">{DePaWSiTKurinBWHMovespeed}</MoveSpeed>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
