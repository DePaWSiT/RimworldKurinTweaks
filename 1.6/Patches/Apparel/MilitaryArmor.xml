<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</li>
      <li>DePaWSiTKurinMilitaryUniformMass</li>
      <li>DePaWSiTKurinMilitaryUniformStuffEffectMultiplier</li>
      <li>DePaWSiTKurinMilitaryUniformShootingAccuracy</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>0.40</li>
      <li>0.30</li>
      <li>2.0</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Military_Uniform"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinMilitaryUniformMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinMilitaryUniformStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <ShootingAccuracyPawn Operation="Replace">{DePaWSiTKurinMilitaryUniformShootingAccuracy}</ShootingAccuracyPawn>
          </equippedStatOffsets>
          <recipeMaker Condition="{DePaWSiTKurinResearchAddFlakToCombatT3Toggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Operation="Add">FlakArmor</li>
            </researchPrerequisites>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
