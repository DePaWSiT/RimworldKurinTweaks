<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- add flak as requirement, Def doesn't have recipeMaker so you get this abomination... -->
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Military_Uniform"]/recipeMaker</xpath>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Military_Uniform"]</xpath>
          <value>
            <recipeMaker>
              <researchPrerequisites>
                <li>FlakArmor</li>
              </researchPrerequisites>
            </recipeMaker>
          </value>
        </nomatch>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Military_Uniform"]/recipeMaker/researchPrerequisites</xpath>
          <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Military_Uniform"]/recipeMaker</xpath>
            <value>
              <researchPrerequisites>
                <li>FlakArmor</li>
              </researchPrerequisites>
            </value>
          </nomatch>
          <match Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="Kurin_OnSkin_Military_Uniform"]/recipeMaker/researchPrerequisites</xpath>
            <value>
              <li>FlakArmor</li>
            </value>
          </match>
        </match>
      </Operation>
    </caseTrue>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinMilitaryUniformMass</key>
    <defaultValue>0.40</defaultValue>
    <apply>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Military_Uniform"]/statBases</xpath>
        <value>
          <Mass>{DePaWSiTKurinMilitaryUniformMass}</Mass>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinMilitaryUniformStuffEffectMultiplier</key>
    <defaultValue>0.30</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Military_Uniform"]/statBases/StuffEffectMultiplierArmor</xpath>
        <value>
          <StuffEffectMultiplierArmor>{DePaWSiTKurinMilitaryUniformStuffEffectMultiplier}</StuffEffectMultiplierArmor>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinMilitaryUniformShootingAccuracy</key>
    <defaultValue>2.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Military_Uniform"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
        <value>
          <ShootingAccuracyPawn>{DePaWSiTKurinMilitaryUniformShootingAccuracy}</ShootingAccuracyPawn>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
