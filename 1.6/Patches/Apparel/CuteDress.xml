<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinCuteDressMoveSpeed</li>
      <li>DePaWSiTKurinCuteDressSocialImpact</li>
      <li>DePaWSiTKurinCuteDressTradeImprovement</li>
    </keys>
    <defaultValues>
      <li>0.40</li>
      <li>0</li>
      <li>0</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Cute_Dress"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <MoveSpeed Operation="Replace">{DePaWSiTKurinCuteDressMoveSpeed}</MoveSpeed>
            <SocialImpact Operation="Add">{DePaWSiTKurinCuteDressSocialImpact}</SocialImpact>
            <TradePriceImprovement Operation="Add">{DePaWSiTKurinCuteDressTradeImprovement}</TradePriceImprovement>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
