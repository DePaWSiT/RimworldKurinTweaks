<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinCWHMass</li>
      <li>DePaWSiTKurinCWHStuffEffectMultiplier</li>
      <li>DePaWSiTKurinCWHMeleeHit</li>
      <li>DePaWSiTKurinCWHMeleeDodge</li>
      <li>DePaWSiTKurinCWHMovespeed</li>
      <li>DePaWSiTKurinMetalApparelAtMachiningTable</li>
    </keys>
    <defaultValues>
      <li>0.20</li>
      <li>0.30</li>
      <li>1.0</li>
      <li>2.0</li>
      <li>0.1</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_Chinese_Wedding_Headwear"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinCWHMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinCWHStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <MeleeHitChance Operation="Replace">{DePaWSiTKurinCWHMeleeHit}</MeleeHitChance>
            <MeleeDodgeChance Operation="Replace">{DePaWSiTKurinCWHMeleeDodge}</MeleeDodgeChance>
            <MoveSpeed Operation="Replace">{DePaWSiTKurinCWHMovespeed}</MoveSpeed>
          </equippedStatOffsets>
          <recipeMaker Condition="{DePaWSiTKurinMetalApparelAtMachiningTable}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">TableMachining</li>
            </recipeUsers>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
