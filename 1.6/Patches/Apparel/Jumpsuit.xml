<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinJumpsuitWorkSpeed</li>
    </keys>
    <defaultValues>
      <li>0.1</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Work_Jumpsuit"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <WorkSpeedGlobal Operation="Replace">{DePaWSiTKurinJumpsuitWorkSpeed}</WorkSpeedGlobal>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
