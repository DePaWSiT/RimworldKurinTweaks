<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinResearchAddFlakToCombatT3Toggle</li>
      <li>DePaWSiTKurinMetalApparelAtMachiningTable</li>
      <li>DePaWSiTKurinMilitaryHelmetMass</li>
      <li>DePaWSiTKurinMilitaryHelmetStuffEffectMultiplier</li>
      <li>DePaWSiTKurinMilitaryHelmetAimTime</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>false</li>
      <li>0.20</li>
      <li>0.45</li>
      <li>-0.1</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_Military_Helmet"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinMilitaryHelmetMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinMilitaryHelmetStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <AimingDelayFactor Operation="Replace">{DePaWSiTKurinMilitaryHelmetAimTime}</AimingDelayFactor>
          </equippedStatOffsets>
          <recipeMaker Condition="{DePaWSiTKurinResearchAddFlakToCombatT3Toggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Operation="Add">FlakArmor</li>
            </researchPrerequisites>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinMetalApparelAtMachiningTable}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">TableMachining</li>
            </recipeUsers>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
