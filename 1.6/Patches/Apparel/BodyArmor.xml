<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinRemoveSmithingFromT2Toggle</li>
      <li>DePaWSiTKurinBodyArmorStuffRating</li>
      <li>DePaWSiTKurinMetalApparelAtMachiningTable</li>
      <li>DePaWSiTKurinBodyArmorToAdvancedCombatToggle</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>1.00</li>
      <li>false</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Middle_Body_Armor"]</xpath>
        <value>
          <statBases Operation="Safe">
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinBodyArmorStuffRating}</StuffEffectMultiplierArmor>
          </statBases>
          <recipeMaker Condition="{DePaWSiTKurinRemoveSmithingFromT2Toggle}" Operation="Safe">
            <researchPrerequisites Operation="Safe">
              <li Operation="Add">FlakArmor</li>
            </researchPrerequisites>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinMetalApparelAtMachiningTable}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">TableMachining</li>
            </recipeUsers>
          </recipeMaker>
          <recipeMaker Condition="{DePaWSiTKurinBodyArmorToAdvancedCombatToggle}" Operation="Safe">
            <researchPrerequisite Operation="Add">Kurin_CombatT3</researchPrerequisite>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
