<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinWWDSocialImpact</key>
    <defaultValue>0.4</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Wedding_Dress_White"]/equippedStatOffsets/SocialImpact</xpath>
        <value>
          <SocialImpact>{DePaWSiTKurinWWDSocialImpact}</SocialImpact>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinWWDTradeImprovement</key>
    <defaultValue>0.25</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Wedding_Dress_White"]/equippedStatOffsets/TradePriceImprovement</xpath>
        <value>
          <TradePriceImprovement>{DePaWSiTKurinWWDTradeImprovement}</TradePriceImprovement>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
