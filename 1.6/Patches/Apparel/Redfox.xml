<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.OptionalPatch">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinPowerArmorFabricationToggle</key>
    <defaultValue>false</defaultValue>
    <caseTrue>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]</xpath>
        <value>
          <recipeMaker>
            <recipeUsers Inherit="False">
              <li>FabricationBench</li>
            </recipeUsers>
          </recipeMaker>
        </value>
      </Operation>
    </caseTrue>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxArmorMass</key>
    <defaultValue>1.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]/statBases</xpath>
        <value>
          <Mass>{DePaWSiTKurinRedfoxArmorMass}</Mass>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxArmorMeleeHit</key>
    <defaultValue>3.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]/equippedStatOffsets/MeleeHitChance</xpath>
        <value>
          <MeleeHitChance>{DePaWSiTKurinRedfoxArmorMeleeHit}</MeleeHitChance>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxArmorShootingAccuracy</key>
    <defaultValue>3.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]/equippedStatOffsets/ShootingAccuracyPawn</xpath>
        <value>
          <ShootingAccuracyPawn>{DePaWSiTKurinRedfoxArmorShootingAccuracy}</ShootingAccuracyPawn>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxArmorDodgeChance</key>
    <defaultValue>3.0</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]/equippedStatOffsets/MeleeDodgeChance</xpath>
        <value>
          <MeleeDodgeChance>{DePaWSiTKurinRedfoxArmorDodgeChance}</MeleeDodgeChance>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxArmorMoveSpeed</key>
    <defaultValue>0.40</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]/equippedStatOffsets/MoveSpeed</xpath>
        <value>
          <MoveSpeed>{DePaWSiTKurinRedfoxArmorMoveSpeed}</MoveSpeed>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting" MayRequire="Ludeon.Rimworld.Odyssey">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinRedfoxArmorVacuumResistance</key>
    <defaultValue>0.3</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]/equippedStatOffsets/VacuumResistance</xpath>
        <value>
          <VacuumResistance MayRequire="Ludeon.Rimworld.Odyssey">{DePaWSiTKurinRedfoxArmorVacuumResistance}</VacuumResistance>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
