<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinPowerArmorFabricationToggle</li>
      <li>DePaWSiTKurinRedfoxArmorMass</li>
      <li>DePaWSiTKurinRedfoxArmorMeleeHit</li>
      <li>DePaWSiTKurinRedfoxArmorShootingAccuracy</li>
      <li>DePaWSiTKurinRedfoxArmorDodgeChance</li>
      <li>DePaWSiTKurinRedfoxArmorMoveSpeed</li>
      <li>DePaWSiTKurinRedfoxArmorVacuumResistance</li>
    </keys>
    <defaultValues>
      <li>false</li>
      <li>1.0</li>
      <li>3.0</li>
      <li>3.0</li>
      <li>9.0</li>
      <li>0.40</li>
      <li>0.3</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Redfox_Armor"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinRedfoxArmorMass}</Mass>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <MeleeHitChance Operation="Replace">{DePaWSiTKurinRedfoxArmorMeleeHit}</MeleeHitChance>
            <ShootingAccuracyPawn Operation="Replace">{DePaWSiTKurinRedfoxArmorShootingAccuracy}</ShootingAccuracyPawn>
            <MeleeDodgeChance Operation="Replace">{DePaWSiTKurinRedfoxArmorDodgeChance}</MeleeDodgeChance>
            <MoveSpeed Operation="Replace">{DePaWSiTKurinRedfoxArmorMoveSpeed}</MoveSpeed>
            <VacuumResistance MayRequire="Ludeon.Rimworld.Odyssey" Operation="Replace">{DePaWSiTKurinRedfoxArmorVacuumResistance}</VacuumResistance>
          </equippedStatOffsets>
          <recipeMaker Condition="{DePaWSiTKurinPowerArmorFabricationToggle}" Operation="Safe">
            <recipeUsers Inherit="False" Operation="Safe">
              <li Operation="Add">FabricationBench</li>
            </recipeUsers>
          </recipeMaker>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
