<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinGothicPinSensitivity</li>
    </keys>
    <defaultValues>
      <li>0.15</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_Gothic_Hair_Pin"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <PsychicSensitivityOffset Operation="Replace">{DePaWSiTKurinGothicPinSensitivity}</PsychicSensitivityOffset>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
