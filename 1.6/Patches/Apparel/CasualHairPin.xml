<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinCasualPinBreakThreshold</li>
      <li>DePaWSiTKurinCasualPinMetalToggle</li>
    </keys>
    <defaultValues>
      <li>-0.06</li>
      <li>false</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_Casual_Hair_Pin"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <MentalBreakThreshold Operation="Replace">{DePaWSiTKurinCasualPinBreakThreshold}</MentalBreakThreshold>
          </equippedStatOffsets>
          <stuffCategories Condition="{DePaWSiTKurinCasualPinMetalToggle}" Inherit="False" Operation="Safe">
            <li Operation="Add">Metallic</li>
          </stuffCategories>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
