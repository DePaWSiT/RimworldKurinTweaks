<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinBlackDressSocialImpact</key>
    <defaultValue>0.25</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Black_Dress"]/equippedStatOffsets/SocialImpact</xpath>
        <value>
          <SocialImpact>{DePaWSiTKurinBlackDressSocialImpact}</SocialImpact>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinBlackDressTradeImprovement</key>
    <defaultValue>0.4</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Black_Dress"]/equippedStatOffsets/TradePriceImprovement</xpath>
        <value>
          <TradePriceImprovement>{DePaWSiTKurinBlackDressTradeImprovement}</TradePriceImprovement>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
