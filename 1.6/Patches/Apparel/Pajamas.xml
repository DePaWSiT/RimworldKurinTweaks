<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.KurinConfigTweaks</modId>
    <key>DePaWSiTKurinPajamasRestMultiplier</key>
    <defaultValue>0.1</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_PajamasA"]/equippedStatOffsets/RestRateMultiplier</xpath>
        <value>
          <RestRateMultiplier>{DePaWSiTKurinPajamasRestMultiplier}</RestRateMultiplier>
        </value>
      </Operation>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_PajamasB"]/equippedStatOffsets/RestRateMultiplier</xpath>
        <value>
          <RestRateMultiplier>{DePaWSiTKurinPajamasRestMultiplier}</RestRateMultiplier>
        </value>
      </Operation>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_PajamasC"]/equippedStatOffsets/RestRateMultiplier</xpath>
        <value>
          <RestRateMultiplier>{DePaWSiTKurinPajamasRestMultiplier}</RestRateMultiplier>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
