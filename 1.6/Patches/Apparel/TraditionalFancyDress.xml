      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Traditional_Fancy_Dress"]/equippedStatOffsets/NegotiationAbility</xpath>
        <value>
          <NegotiationAbility>{DePaWSiTKurinTFDNegAbility}</NegotiationAbility>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinTFDTradeImprovement</key>
    <defaultValue>0.15</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Traditional_Fancy_Dress"]/equippedStatOffsets/TradePriceImprovement</xpath>
        <value>
          <TradePriceImprovement>{DePaWSiTKurinTFDTradeImprovement}</TradePriceImprovement>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
