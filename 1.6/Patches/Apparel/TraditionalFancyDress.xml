<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinTFDSocialImpact</li>
      <li>DePaWSiTKurinTFDNegAbility</li>
      <li>DePaWSiTKurinTFDTradeImprovement</li>
    </keys>
    <defaultValues>
      <li>0.15</li>
      <li>0.15</li>
      <li>0.15</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Traditional_Fancy_Dress"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <SocialImpact Operation="Replace">{DePaWSiTKurinTFDSocialImpact}</SocialImpact>
            <NegotiationAbility Operation="Replace">{DePaWSiTKurinTFDNegAbility}</NegotiationAbility>
            <TradePriceImprovement Operation="Replace">{DePaWSiTKurinTFDTradeImprovement}</TradePriceImprovement>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
