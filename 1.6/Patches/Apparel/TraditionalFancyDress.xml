<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinTFDSocialImpact</key>
    <defaultValue>0.15</defaultValue>
    <apply>
      <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Traditional_Fancy_Dress"]/equippedStatOffsets/SocialImpact</xpath>
        <value>
          <SocialImpact>{DePaWSiTKurinTFDSocialImpact}</SocialImpact>
        </value>
      </Operation>
    </apply>
  </Operation>
  <Operation Class="XmlExtensions.UseSetting">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <key>DePaWSiTKurinTFDNegAbility</key>
    <defaultValue>0.15</defaultValue>
