<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinResearchClothingHackingSpeed</li>
      <li>DePaWSiTKurinResearchClothingResearchSpeed</li>
    </keys>
    <defaultValues>
      <li>0.3</li>
      <li>0.2</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Research_Clothing"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <HackingSpeed Operation="Replace">{DePaWSiTKurinResearchClothingHackingSpeed}</HackingSpeed>
            <ResearchSpeed Operation="Replace">{DePaWSiTKurinResearchClothingResearchSpeed}</ResearchSpeed>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
