<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinBWDSocialImpact</li>
      <li>DePaWSiTKurinBWDTradeImprovement</li>
    </keys>
    <defaultValues>
      <li>0.25</li>
      <li>0.4</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Wedding_Dress_Black"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <SocialImpact Operation="Replace">{DePaWSiTKurinBWDSocialImpact}</SocialImpact>
            <TradePriceImprovement Operation="Replace">{DePaWSiTKurinBWDTradeImprovement}</TradePriceImprovement>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
