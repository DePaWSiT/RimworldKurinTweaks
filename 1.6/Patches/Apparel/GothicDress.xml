<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinGothicDressSensitivity</li>
      <li>DePaWSiTKurinGothicDressEntropyRecoveryRate</li>
    </keys>
    <defaultValues>
      <li>0.25</li>
      <li>0.03</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_OnSkin_Gothic_Dress"]</xpath>
        <value>
          <equippedStatOffsets Operation="Safe">
            <PsychicSensitivityOffset Operation="Replace">{DePaWSiTKurinGothicDressSensitivity}</PsychicSensitivityOffset>
            <PsychicEntropyRecoveryRate Operation="Replace">{DePaWSiTKurinGothicDressEntropyRecoveryRate}</PsychicEntropyRecoveryRate>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
