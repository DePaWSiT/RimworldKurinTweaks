<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="XmlExtensions.UseSettings">
    <modId>DePaWSiT.Kurin.ConfigTweaks</modId>
    <keys>
      <li>DePaWSiTKurinWWHMass</li>
      <li>DePaWSiTKurinWWHStuffEffectMultiplier</li>
      <li>DePaWSiTKurinWWHMeleeHit</li>
      <li>DePaWSiTKurinWWHMeleeDodge</li>
      <li>DePaWSiTKurinWWHMovespeed</li>
    </keys>
    <defaultValues>
      <li>0.20</li>
      <li>0.30</li>
      <li>1.0</li>
      <li>2.0</li>
      <li>0.1</li>
    </defaultValues>
    <apply>
      <Operation Class="XmlExtensions.HybridPatch">
        <xpath>Defs/ThingDef[defName = "Kurin_Overhead_White_Wedding_Headwear"]</xpath>
        <value>
          <statBases Operation="Safe">
            <Mass Operation="Add">{DePaWSiTKurinWWHMass}</Mass>
            <StuffEffectMultiplierArmor Operation="Replace">{DePaWSiTKurinWWHStuffEffectMultiplier}</StuffEffectMultiplierArmor>
          </statBases>
          <equippedStatOffsets Operation="Safe">
            <MeleeHitChance Operation="Replace">{DePaWSiTKurinWWHMeleeHit}</MeleeHitChance>
            <MeleeDodgeChance Operation="Replace">{DePaWSiTKurinWWHMeleeDodge}</MeleeDodgeChance>
            <MoveSpeed Operation="Replace">{DePaWSiTKurinWWHMovespeed}</MoveSpeed>
          </equippedStatOffsets>
        </value>
      </Operation>
    </apply>
  </Operation>
</Patch>
